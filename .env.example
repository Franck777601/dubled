## Configuration de l'application ISPA Forms

# Numéro WhatsApp destinataire (avec code pays)
WHATSAPP_PHONE=15559707710

# Port du serveur Node.js
PORT=3000

# Environnement
NODE_ENV=development

# Google Apps Script Web App URL (pour l'enregistrement des prospects dans Google Sheets)
# Récupérez cette URL après avoir déployé le script depuis crm_export/create_ispa_crm.gs
# Format: https://script.google.com/macros/d/XXXXXXXXXXXXXX/userweb
GOOGLE_APPS_SCRIPT_URL=

## Pour les fichiers ISBITAGES (dans le dossier ISBITAGES/)
# Vous pouvez avoir une variable spécifique pour ISBITAGES si besoin :
# GOOGLE_APPS_SCRIPT_URL_ISBITAGES=
